---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada" noindex>
  <div class="container-page py-24 text-center">
    <p class="text-6xl font-bold text-brand-700">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold text-ink-900 dark:text-white">Página no encontrada</h1>
    <p class="mt-2 text-ink-500">La página que buscás no existe o fue movida.</p>
    <a href="/" class="btn-primary mt-6">Volver al inicio</a>
  </div>
</Layout>
