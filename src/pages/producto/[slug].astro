---
import Layout from '../../layouts/Layout.astro';
import ProductGallery from '../../components/ProductGallery.tsx';
import ReviewForm from '../../components/ReviewForm.tsx';
import ProductCard from '../../components/ProductCard.astro';
import { getAllProducts, getProductBySlug, getProductReviews, getRelatedProducts, getSiteConfig } from '../../lib/queries';
import { formatPrice, discountPercent, parseFeatures, whatsappUrl, formatDate } from '../../lib/utils';
import { productJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = await getProductBySlug(slug as string);
if (!product) {
  return Astro.redirect('/404');
}

const [reviews, related, config] = await Promise.all([
  getProductReviews(product.id),
  getRelatedProducts({ category_id: product.category_id, id: product.id }, 4),
  getSiteConfig(),
]);

const features = parseFeatures(product.features);
const discount = discountPercent(product.price, product.compare_price);
const out = product.stock <= 0;
const whatsapp = config?.whatsapp ?? '5493516996607';
const origin = Astro.site?.origin ?? 'https://elohimdescartabless.netlify.app';

const orderText = `¡Hola! Quiero hacer un pedido:\n*Producto:* ${product.name}\n*Precio:* ${formatPrice(product.price)}\n*Categoría:* ${product.category?.name ?? '-'}`;
const jsonLd = productJsonLd(product as any, origin);
---

<Layout
  title={product.name}
  description={product.description ?? `Comprá ${product.name} al por mayor y menor en Elohim Descartables.`}
  image={product.product_images?.[0]?.url}
  canonical={`${origin}/producto/${product.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...jsonLd })} />

  <div class="container-page py-8 sm:py-10">
    <nav class="text-sm text-ink-500 dark:text-ink-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand-700">Inicio</a>
      <span class="mx-1">/</span>
      <a href="/catalogo" class="hover:text-brand-700">Catálogo</a>
      <span class="mx-1">/</span>
      {product.category && <><a href={`/catalogo?cat=${product.category.slug}`} class="hover:text-brand-700">{product.category.name}</a><span class="mx-1">/</span></>}
      <span class="text-ink-700 dark:text-ink-200">{product.name}</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-2">
      <ProductGallery client:visible images={product.product_images ?? []} name={product.name} />

      <div>
        <div class="flex flex-wrap gap-2 mb-3">
          {product.badges.includes('nuevo') && <span class="badge-new">Nuevo</span>}
          {discount > 0 && <span class="badge-sale">-{discount}% OFF</span>}
          {product.badges.includes('destacado') && <span class="badge-feat">Destacado</span>}
          {out
            ? <span class="badge-out">Sin stock</span>
            : <span class="badge-stock">En stock ({product.stock})</span>}
        </div>

        {product.category?.name && <p class="text-xs uppercase tracking-wide text-ink-500">{product.category.name}</p>}
        <h1 class="mt-1 font-display text-3xl font-bold text-ink-900 dark:text-white sm:text-4xl">{product.name}</h1>
        {product.brand?.name && <p class="mt-1 text-sm text-ink-500">Marca: <span class="font-medium text-ink-700 dark:text-ink-200">{product.brand.name}</span></p>}

        {product.rating > 0 && (
          <div class="mt-3 flex items-center gap-2">
            <div class="flex text-accent-500">
              {[1,2,3,4,5].map((n) => (
                <svg class={n <= Math.round(product.rating) ? 'h-4 w-4' : 'h-4 w-4 text-ink-300'} fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.5 3 1.5-6L2 7.5l6-.5L10 1l2 6 6 .5-4 4.5 1.5 6z"/></svg>
              ))}
            </div>
            <span class="text-sm text-ink-500">{product.rating.toFixed(1)} · {product.reviews_count} opiniones</span>
          </div>
        )}

        <div class="mt-5 flex items-baseline gap-3">
          <span class="text-3xl font-bold text-brand-700 dark:text-brand-300">{formatPrice(product.price)}</span>
          {product.compare_price && product.compare_price > product.price && (
            <span class="text-lg text-ink-400 line-through">{formatPrice(product.compare_price)}</span>
          )}
          {product.unit && <span class="text-sm text-ink-500">/ {product.unit}</span>}
        </div>

        {product.description && <p class="mt-5 text-ink-600 dark:text-ink-300 leading-relaxed">{product.description}</p>}

        {features.length > 0 && (
          <div class="mt-6">
            <h2 class="font-semibold text-ink-900 dark:text-white mb-3">Características</h2>
            <ul class="space-y-2">
              {features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-ink-700 dark:text-ink-200">
                  <svg class="h-4 w-4 mt-0.5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={whatsappUrl(whatsapp, orderText)} target="_blank" rel="noopener" class="btn-primary">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24z"/></svg>
            Pedir por WhatsApp
          </a>
          <button id="share-btn" class="btn-outline">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.7 10.7l6.6-3.4M8.7 13.3l6.6 3.4M18 12a3 3 0 11-6 0 3 3 0 016 0zM9 6a3 3 0 11-6 0 3 3 0 016 0zM9 18a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Compartir
          </button>
        </div>

        {product.sku && <p class="mt-6 text-xs text-ink-400">SKU: {product.sku}</p>}
      </div>
    </div>

    <!-- Reviews -->
    <section class="mt-14">
      <h2 class="section-title mb-6">Opiniones ({reviews.length})</h2>
      <div class="grid gap-6 lg:grid-cols-[1fr_360px]">
        <div class="space-y-4">
          {reviews.length === 0 ? (
            <div class="card p-6 text-ink-500">Todavía no hay opiniones. ¡Sé el primero!</div>
          ) : (
            reviews.map((r) => (
              <article class="card p-5">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-100 text-brand-700 font-bold text-sm">{r.author.slice(0,1)}</div>
                    <div>
                      <p class="font-semibold text-ink-900 dark:text-white text-sm">{r.author}</p>
                      <p class="text-xs text-ink-400">{formatDate(r.created_at)}</p>
                    </div>
                  </div>
                  <div class="flex text-accent-500">
                    {[1,2,3,4,5].map((n) => <svg class={n <= r.rating ? 'h-4 w-4' : 'h-4 w-4 text-ink-300'} fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.5 3 1.5-6L2 7.5l6-.5L10 1l2 6 6 .5-4 4.5 1.5 6z"/></svg>)}
                  </div>
                </div>
                {r.comment && <p class="mt-3 text-ink-700 dark:text-ink-200 text-sm">{r.comment}</p>}
              </article>
            ))
          )}
        </div>
        <ReviewForm client:visible productId={product.id} />
      </div>
    </section>

    <!-- Related -->
    {related.length > 0 && (
      <section class="mt-14">
        <h2 class="section-title mb-6">Productos relacionados</h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {related.map((p) => <ProductCard product={p as any} />)}
        </div>
      </section>
    )}
  </div>

  <script is:inline>
    document.getElementById('share-btn')?.addEventListener('click', async () => {
      const url = window.location.href;
      if (navigator.share) {
        try { await navigator.share({ title: document.title, url }); } catch {}
      } else {
        try { await navigator.clipboard.writeText(url); alert('Enlace copiado al portapapeles'); } catch {}
      }
    });
  </script>
</Layout>
