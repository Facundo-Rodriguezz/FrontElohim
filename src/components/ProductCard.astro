---
import type { Product } from '../lib/supabase';
import { formatPrice, discountPercent, classNames } from '../lib/utils';

interface Props {
  product: Product;
  loading?: 'lazy' | 'eager';
}

const { product, loading = 'lazy' } = Astro.props;
const img = product.product_images?.[0]?.url ?? '/images/bandejas-termicas.jpg';
const alt = product.product_images?.[0]?.alt ?? product.name;
const discount = discountPercent(product.price, product.compare_price);
const outOfStock = product.stock <= 0;
const isNew = product.badges?.includes('nuevo');
const isSale = product.badges?.includes('oferta') || discount > 0;
const isFeatured = product.badges?.includes('destacado');
const stockLabel = outOfStock ? 'Sin stock' : product.stock <= 10 ? `¡Últimas ${product.stock}!` : 'En stock';
---

<a href={`/producto/${product.slug}`} class="card group block overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover">
  <div class="relative aspect-square overflow-hidden bg-ink-100 dark:bg-ink-800">
    <img
      src={img}
      alt={alt}
      loading={loading}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute left-2 top-2 flex flex-col gap-1.5">
      {isNew && <span class="badge-new">Nuevo</span>}
      {isSale && discount > 0 && <span class="badge-sale">-{discount}%</span>}
      {isFeatured && <span class="badge-feat">Destacado</span>}
    </div>
    {outOfStock && (
      <div class="absolute inset-0 flex items-center justify-center bg-white/60 dark:bg-ink-950/60">
        <span class="badge-out !text-sm !py-1.5 !px-3">Sin stock</span>
      </div>
    )}
  </div>
  <div class="p-4">
    {product.category?.name && (
      <p class="text-xs font-medium uppercase tracking-wide text-ink-500 dark:text-ink-400">{product.category.name}</p>
    )}
    <h3 class="mt-1 line-clamp-2 font-semibold text-ink-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300" title={product.name}>
      {product.name}
    </h3>
    {product.brand?.name && <p class="mt-0.5 text-xs text-ink-500">{product.brand.name}</p>}
    <div class="mt-3 flex items-baseline gap-2">
      <span class="text-lg font-bold text-brand-700 dark:text-brand-300">{formatPrice(product.price)}</span>
      {product.compare_price && product.compare_price > product.price && (
        <span class="text-sm text-ink-400 line-through">{formatPrice(product.compare_price)}</span>
      )}
    </div>
    <div class="mt-3 flex items-center justify-between">
      <span class={classNames('text-xs', outOfStock ? 'text-ink-400' : 'text-emerald-600 dark:text-emerald-400')}>
        {stockLabel}
      </span>
      <span class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 opacity-0 transition group-hover:opacity-100 dark:text-brand-300">
        Ver
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</a>
