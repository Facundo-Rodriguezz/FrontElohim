---
import { getSiteConfig, getPromotions, getCategories, getFeaturedProducts, getBrands } from '../lib/queries';
import ProductCard from './ProductCard.astro';

const config = await getSiteConfig();
const promotions = await getPromotions();
const categories = await getCategories();
const featured = await getFeaturedProducts(8);
const brands = await getBrands();

const benefits = [
  { title: 'Envío a Córdoba', desc: 'Entregamos en toda Córdoba Capital y alrededores.', icon: 'truck' },
  { title: 'Precios mayoristas', desc: 'Comprá al por mayor y obtené mejores precios.', icon: 'tags' },
  { title: 'Calidad garantizada', desc: 'Productos seleccionados que cumplen estándares.', icon: 'shield' },
  { title: 'Atención personalizada', desc: 'Te asesoramos por WhatsApp de lun a vie.', icon: 'phone' },
];

const faqs = [
  { q: '¿Hacen envíos?', a: 'Sí, realizamos envíos a toda Córdoba Capital y alrededores. El costo se confirma según la zona al momento del pedido.' },
  { q: '¿Cuál es el pedido mínimo?', a: 'Trabajamos al por mayor y menor. No hay mínimo para retiro en sucursal; para envío consultá por WhatsApp.' },
  { q: '¿Cómo pago?', a: 'Aceptamos transferencia, efectivo yMercado Pago. El detalle se coordina con nuestro equipo al confirmar el pedido.' },
  { q: '¿Tienen descuentos por cantidad?', a: 'Sí, en pedidos mayoristas aplicamos precios especiales. Escribinos por WhatsApp con tu lista.' },
];

const reviews = [
  { name: 'Carla M.', text: 'Excelente calidad y envío rápido. Los vasos térmicos llegaron impecables.', role: 'Cafetería Centro' },
  { name: 'Jorge R.', text: 'Compramos cajas para la rotisería cada semana, siempre bien atendidos.', role: 'Rotisería Don Jorge' },
  { name: 'Lucía P.', text: 'Las servilletas son suaves y los diseños muy lindos. Súper recomendables.', role: 'Eventos Lucía' },
];
---

<!-- HERO -->
<section class="relative overflow-hidden bg-gradient-to-br from-brand-700 via-brand-800 to-brand-950 text-white">
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, rgba(255,255,255,.4) 0, transparent 40%), radial-gradient(circle at 80% 70%, rgba(249,144,23,.5) 0, transparent 40%);"></div>
  <div class="container-page relative grid gap-10 py-16 md:py-24 lg:grid-cols-2 lg:items-center">
    <div class="animate-fade-up">
      <span class="badge bg-white/15 text-white backdrop-blur">Descartables al por mayor y menor</span>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
        {config?.hero_title ?? 'Productos descartables de alta calidad'}
      </h1>
      <p class="mt-4 max-w-xl text-lg text-white/85">
        {config?.hero_subtitle ?? 'Vasos, bolsas, cubiertos, bandejas, servilletas y todo lo que tu negocio necesita, con envío a Córdoba Capital.'}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/catalogo" class="btn bg-white text-brand-700 hover:bg-ink-100">
          Ver catálogo
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
        {config?.whatsapp && (
          <a href={`https://wa.me/${config.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="btn border border-white/40 text-white hover:bg-white/10">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.207z"/></svg>
            Pedir por WhatsApp
          </a>
        )}
      </div>
      <div class="mt-10 flex gap-8">
        <div><p class="text-3xl font-bold">+4 años</p><p class="text-sm text-white/70">de experiencia</p></div>
        <div><p class="text-3xl font-bold">+500</p><p class="text-sm text-white/70">clientes activos</p></div>
        <div><p class="text-3xl font-bold">100%</p><p class="text-sm text-white/70">calidad garantizada</p></div>
      </div>
    </div>
    {config?.hero_image_url && (
      <div class="relative hidden lg:block animate-fade-in">
        <div class="absolute -inset-4 rounded-3xl bg-white/10 blur-xl"></div>
        <img src={config.hero_image_url} alt="Elohim Descartables" class="relative rounded-3xl shadow-2xl" loading="eager" />
      </div>
    )}
  </div>
</section>

<!-- PROMOTION BANNER -->
{promotions.length > 0 && (
  <section class="container-page -mt-8 relative z-10">
    <div class="card flex flex-col gap-4 overflow-hidden p-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
        <span class="badge-sale !text-sm !px-3 !py-1">{promotions[0].badge ?? 'Promo'}</span>
        <div>
          <p class="font-display text-lg font-semibold text-ink-900 dark:text-white">{promotions[0].title}</p>
          <p class="text-sm text-ink-500 dark:text-ink-400">{promotions[0].subtitle}</p>
        </div>
      </div>
      {promotions[0].cta_link && (
        <a href={promotions[0].cta_link} class="btn-primary shrink-0">
          {promotions[0].cta_text ?? 'Ver más'}
        </a>
      )}
    </div>
  </section>
)}

<!-- BENEFITS -->
<section class="container-page py-14">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {benefits.map((b) => (
      <div class="card p-5 flex items-start gap-3 transition hover:shadow-card-hover">
        <div class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-brand-50 text-brand-700 dark:bg-brand-900/30 dark:text-brand-300">
          {b.icon === 'truck' && <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7h11v8H3zM14 10h4l3 3v2h-7M5.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm12 0a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/></svg>}
          {b.icon === 'tags' && <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5a2 2 0 011.41.59l8 8a2 2 0 010 2.82l-5 5a2 2 0 01-2.82 0l-8-8A2 2 0 013 10V5a2 2 0 012-2z"/></svg>}
          {b.icon === 'shield' && <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l8 4v5c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V7l8-4z"/></svg>}
          {b.icon === 'phone' && <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.5a1 1 0 01.95.68l1.2 3.6a1 1 0 01-.27 1.05L8 9.5a12 12 0 006 6l1.17-1.38a1 1 0 011.05-.27l3.6 1.2a1 1 0 01.68.95V19a2 2 0 01-2 2A16 16 0 013 5z"/></svg>}
        </div>
        <div>
          <p class="font-semibold text-ink-900 dark:text-white">{b.title}</p>
          <p class="text-sm text-ink-500 dark:text-ink-400">{b.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CATEGORIES -->
<section id="categorias" class="container-page py-12">
  <div class="flex items-end justify-between gap-4 mb-8">
    <div>
      <h2 class="section-title">Comprar por categorías</h2>
      <p class="section-sub mt-1">Encontrá lo que buscás rápido.</p>
    </div>
    <a href="/catalogo" class="hidden sm:inline-flex btn-outline">Ver todo</a>
  </div>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
    {categories.map((c) => (
      <a href={`/catalogo?cat=${c.slug}`} class="card group flex flex-col items-center gap-3 p-5 text-center transition hover:-translate-y-1 hover:shadow-card-hover">
        <div class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-50 text-brand-700 transition group-hover:bg-brand-700 group-hover:text-white dark:bg-brand-900/30 dark:text-brand-300">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M7 12h10"/></svg>
        </div>
        <p class="text-sm font-semibold text-ink-900 dark:text-white">{c.name}</p>
      </a>
    ))}
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="bg-ink-100/60 dark:bg-ink-900/40 py-14">
  <div class="container-page">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <h2 class="section-title">Productos destacados</h2>
        <p class="section-sub mt-1">Lo más elegido por nuestros clientes.</p>
      </div>
      <a href="/catalogo" class="btn-outline">Ver catálogo completo</a>
    </div>
    {featured.length === 0 ? (
      <p class="text-ink-500">Aún no hay productos destacados. Agregá productos desde el panel de administración.</p>
    ) : (
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {featured.map((p) => <ProductCard product={p as any} />)}
      </div>
    )}
  </div>
</section>

<!-- BRANDS -->
{brands.length > 0 && (
  <section class="container-page py-12">
    <h2 class="section-title text-center mb-8">Marcas que trabajamos</h2>
    <div class="flex flex-wrap items-center justify-center gap-6">
      {brands.map((b) => (
        <div class="card flex items-center gap-3 px-6 py-4">
          {b.logo_url
            ? <img src={b.logo_url} alt={b.name} class="h-8 w-8 rounded object-cover" />
            : <span class="grid h-8 w-8 place-items-center rounded bg-ink-100 text-xs font-bold text-ink-600 dark:bg-ink-800 dark:text-ink-300">{b.name.slice(0,2).toUpperCase()}</span>}
          <span class="font-semibold text-ink-800 dark:text-ink-100">{b.name}</span>
        </div>
      ))}
    </div>
  </section>
)}

<!-- COMPANY -->
<section id="empresa" class="container-page py-14">
  <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
    <div class="relative">
      <img src="/images/bandejas-termicas.jpg" alt="Elohim Descartables" class="w-full rounded-2xl shadow-card-hover" loading="lazy" />
      <div class="absolute -bottom-6 -right-6 hidden sm:block card p-5 w-44">
        <p class="text-3xl font-bold text-brand-700">+4</p>
        <p class="text-sm text-ink-500">años de experiencia</p>
      </div>
    </div>
    <div>
      <h2 class="section-title">Quiénes somos</h2>
      <p class="mt-4 text-ink-600 dark:text-ink-300 leading-relaxed">
        Elohim Descartables es una empresa líder en la distribución de productos descartables de alta calidad.
        Con más de 4 años de experiencia en el mercado, nos hemos consolidado como un proveedor confiable y eficiente.
      </p>
      <ul class="mt-6 space-y-3">
        {['Calidad garantizada en todos nuestros productos', 'Precios competitivos al por mayor y menor', 'Entrega rápida en Córdoba Capital', 'Atención personalizada por WhatsApp'].map((item) => (
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 mt-0.5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-ink-700 dark:text-ink-200">{item}</span>
          </li>
        ))}
      </ul>
      <a href="/#pedidos" class="mt-8 btn-primary">Realizar un pedido</a>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="bg-ink-100/60 dark:bg-ink-900/40 py-14">
  <div class="container-page">
    <h2 class="section-title text-center mb-2">Lo que dicen nuestros clientes</h2>
    <p class="section-sub text-center mb-10">Reseñas reales de clientes que confían en nosotros.</p>
    <div class="grid gap-6 md:grid-cols-3">
      {reviews.map((r) => (
        <div class="card p-6">
          <div class="flex gap-1 text-accent-500 mb-3">
            {[1,2,3,4,5].map(() => <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.5 3 1.5-6L2 7.5l6-.5L10 1l2 6 6 .5-4 4.5 1.5 6z"/></svg>)}
          </div>
          <p class="text-ink-700 dark:text-ink-200">"{r.text}"</p>
          <div class="mt-4 flex items-center gap-3">
            <div class="grid h-10 w-10 place-items-center rounded-full bg-brand-100 text-brand-700 font-bold">{r.name.slice(0,1)}</div>
            <div>
              <p class="font-semibold text-ink-900 dark:text-white">{r.name}</p>
              <p class="text-xs text-ink-500">{r.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="container-page py-14">
  <div class="grid gap-10 lg:grid-cols-3">
    <div class="lg:col-span-1">
      <h2 class="section-title">Preguntas frecuentes</h2>
      <p class="section-sub mt-2">¿No encontrás tu respuesta? Escribinos por WhatsApp.</p>
    </div>
    <div class="lg:col-span-2 space-y-3">
      {faqs.map((f) => (
        <details class="card group p-5 [&_summary]:cursor-pointer">
          <summary class="flex items-center justify-between gap-4 font-semibold text-ink-900 dark:text-white list-none">
            {f.q}
            <svg class="h-5 w-5 text-ink-400 transition group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-ink-600 dark:text-ink-300">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- NEWSLETTER + CTA -->
<section class="container-page py-12">
  <div class="rounded-2xl bg-brand-700 px-6 py-12 text-center text-white sm:px-12">
    <h2 class="font-display text-2xl sm:text-3xl font-bold">{config?.newsletter_title ?? 'Suscribite y recibí ofertas exclusivas'}</h2>
    <p class="mt-2 text-white/85">Enterate antes que nadie de promociones, descuentos y productos nuevos.</p>
    <form class="mt-6 mx-auto flex max-w-md flex-col gap-3 sm:flex-row" onsubmit="return false;">
      <input type="email" placeholder="Tu email" aria-label="Email" class="rounded-lg border-0 px-4 py-2.5 text-ink-900 placeholder-ink-400 focus:ring-2 focus:ring-white" required />
      <button type="submit" class="btn bg-white text-brand-700 hover:bg-ink-100">Suscribirme</button>
    </form>
  </div>
</section>
