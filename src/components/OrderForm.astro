---
import { getSiteConfig } from '../lib/queries';
const config = await getSiteConfig();
const whatsapp = config?.whatsapp ?? '5493516996607';
---

<section id="pedidos" class="bg-ink-100/60 dark:bg-ink-900/40 py-14">
  <div class="container-page max-w-3xl">
    <div class="text-center mb-8">
      <h2 class="section-title">Realizar pedido</h2>
      <p class="section-sub mt-1">Completá el formulario y lo enviamos por WhatsApp.</p>
    </div>
    <form id="order-form" class="card p-6 sm:p-8 space-y-5">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="label" for="nombre">Nombre *</label>
          <input class="input" id="nombre" name="nombre" required placeholder="Tu nombre completo" />
        </div>
        <div>
          <label class="label" for="telefono">Teléfono *</label>
          <input class="input" id="telefono" name="telefono" type="tel" required placeholder="Ej: 351 1234567" />
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="label" for="calle">Calle *</label>
          <input class="input" id="calle" name="calle" required placeholder="Nombre de la calle" />
        </div>
        <div>
          <label class="label" for="numeracion">Numeración *</label>
          <input class="input" id="numeracion" name="numeracion" required placeholder="Número" />
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <label class="label" for="piso">Piso</label>
          <input class="input" id="piso" name="piso" placeholder="Opcional" />
        </div>
        <div>
          <label class="label" for="departamento">Departamento</label>
          <input class="input" id="departamento" name="departamento" placeholder="Opcional" />
        </div>
        <div>
          <label class="label" for="localidad">Localidad *</label>
          <input class="input" id="localidad" name="localidad" required placeholder="Ej: Córdoba" />
        </div>
      </div>
      <div>
        <label class="label" for="provincia">Provincia *</label>
        <input class="input" id="provincia" name="provincia" required placeholder="Ej: Córdoba" />
      </div>
      <div>
        <label class="label" for="pedido">Detalle del pedido *</label>
        <textarea class="input" id="pedido" name="pedido" rows="4" required placeholder="Productos, cantidades, etc."></textarea>
      </div>
      <button type="submit" class="btn-primary w-full">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.207z"/></svg>
        Enviar pedido por WhatsApp
      </button>
    </form>
  </div>
</section>

<script is:inline define:vars={{ whatsapp }}>
  const form = document.getElementById('order-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const get = (id) => (document.getElementById(id)?.value || '').trim();
    const pedido = get('pedido');
    if (!pedido) { alert('Escribí el detalle del pedido.'); return; }
    let msg = '¡Hola! Quiero realizar un pedido:\n\n';
    msg += `*Nombre:* ${get('nombre')}\n`;
    msg += `*Teléfono:* ${get('telefono')}\n`;
    msg += `*Dirección:* ${get('calle')} ${get('numeracion')}`;
    if (get('piso')) msg += `, Piso: ${get('piso')}`;
    if (get('departamento')) msg += `, Dpto: ${get('departamento')}`;
    msg += `\n*Localidad:* ${get('localidad')}\n`;
    msg += `*Provincia:* ${get('provincia')}\n`;
    msg += `*Pedido:* ${pedido}\n`;
    window.open(`https://wa.me/${whatsapp}?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
